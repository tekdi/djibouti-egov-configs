{
  "key": "studio-application",
  "DataConfigs": {
    "serviceName": "public-services",
    "version": "1.0.0",
    "baseKeyPath": "$.Application.*",
    "entityIdPath": "$.id",
    "mappings": [
      {
        "mappings": [
          {
            "direct": [
              {
                "variable": "applicationNumber",
                "value": {
                  "path": "$.applicationNumber"
                }
              },
              {
                "variable": "module",
                "value": {
                  "path": "$.module"
                }
              },
              {
                "variable": "businessService",
                "value": {
                  "path": "$.businessService"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}